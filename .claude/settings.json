{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "WebSearch",
      "WebFetch(*)",
      "Skill(update-config)",
      "mcp__Claude_Preview__preview_start"
    ],
    "deny": [
      "Bash(brew install *)",
      "Bash(brew reinstall *)",
      "Bash(brew upgrade *)",
      "Bash(brew tap *)",
      "Bash(sudo *)",
      "Bash(wget *)",
      "Bash(pip install *)",
      "Bash(pip3 install *)",
      "Bash(npm install *)",
      "Bash(npm i *)",
      "Bash(npx *)",
      "Bash(cargo install *)",
      "Bash(gem install *)",
      "Bash(apt install *)",
      "Bash(apt-get install *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "A source file was just modified. If the change affects architecture, modules, security, QoS, concurrency, protocol, or configuration, check whether CLAUDE.md or ARCHITECTURE.md need updating to stay consistent with the code. If they do, update them. Ignore changes to CLAUDE.md and ARCHITECTURE.md themselves."
          }
        ]
      }
    ]
  }
}
